# Configuração opcional do Braz Solar Scan Desktop.
# Renomeie para desktop.env e mantenha ao lado de BrazSolarScan.exe,
# ou salve em %APPDATA%\BrazSolarScan\desktop.env.

# E-mail real para criação de conta e recuperação de senha.
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.gmail.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=true
DJANGO_EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=

# Integrações opcionais.
NREL_API_KEY=
NREL_FULL_NAME=
NREL_EMAIL=
NREL_AFFILIATION=
NREL_REASON=research
