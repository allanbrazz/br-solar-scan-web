DJANGO_ENV=dev
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DJANGO_ALLOW_PUBLIC_SIGNUP=true

# Local SQLite. In production, prefer DATABASE_URL/PostgreSQL.
DJANGO_DB_NAME=db.sqlite3
SOLARCONTROL_DATA_DIR=.runtime

NREL_API_KEY=
NREL_FULL_NAME=
NREL_EMAIL=
NREL_AFFILIATION=
NREL_REASON=research

RENOVIGI_COMPANY_KEY=

# E-mail. Em producao, use o backend SMTP e uma senha de aplicativo.
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_EMAIL_HOST=smtp.gmail.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=true
DJANGO_EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=
ACCOUNT_LOGIN_URL=http://127.0.0.1:8000/accounts/login/
